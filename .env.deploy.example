# Salin file ini menjadi .env di server Ubuntu, lalu ganti nilainya.

# Aplikasi hanya dibuka lewat IP Tailscale server.
TAILSCALE_IP=100.66.177.8
APP_PORT=8081

# Akun admin aplikasi.
LOCAL_ADMIN_EMAIL=admin@example.com
LOCAL_ADMIN_PASSWORD=ganti-password-yang-kuat

# Buat nilai acak panjang dengan:
# openssl rand -hex 32
TOKEN_SECRET=ganti-dengan-token-secret-panjang-dan-acak
